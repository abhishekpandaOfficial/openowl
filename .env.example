# ═══════════════════════════════════════════════════════════
# OpenOwl Configuration Template
# Copy this to .env and fill in your values
# cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
DEBUG=false
OWNER_ID=your-telegram-user-id   # Get from @userinfobot on Telegram

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://openowl:openowl@localhost:5432/openowl
REDIS_URL=redis://localhost:6379/0

# ── Telegram ─────────────────────────────────────────────────
# 1. Message @BotFather on Telegram
# 2. Send /newbot → follow prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN="8723036194:AAEpo0f0ITFKKVbMhZ5hNGxVgBXtLptM4ko"

# Your public URL (from ngrok or Railway)
# Run: ngrok http 8000 → copy the https URL
# TELEGRAM_WEBHOOK_URL=https://3f72-2401-4900-8fd1-f87d-dd47-f555-d6f1-a46e.ngrok-free.app -> http://localhost:8000
# TELEGRAM_WEBHOOK_URL=https://3f72-2401-4900-8fd1-f87d-dd47-f555-d6f1-a46e.ngrok-free.app/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://3f72-2401-4900-8fd1-f87d-dd47-f555-d6f1-a46e.ngrok-free.app
# ── Twilio (WhatsApp + SMS + Phone) ──────────────────────────
# Sign up at twilio.com (free $15 trial credit)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Twilio sandbox number

# ── AI Models — FILL AT LEAST ONE ────────────────────────────

# RECOMMENDED: Groq (free, fast, OSS models)
# Sign up at console.groq.com — it's free
GROQ_API_KEY=

# Optional: Ollama runs locally (no API key needed)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Optional cloud fallbacks (only used if Groq + Ollama both fail)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Agent Settings ────────────────────────────────────────────
DEFAULT_PERSONA=aria
MAX_TOKENS=1024
TEMPERATURE=0.7
CONTEXT_WINDOW=10

# ── Guardrails (keep these true!) ────────────────────────────
REQUIRE_APPROVAL_FOR_PAYMENTS=true
REQUIRE_APPROVAL_FOR_EMAILS=true
REQUIRE_APPROVAL_FOR_MESSAGES=true
APPROVAL_TIMEOUT_SECONDS=300

# ── Webhook Security ──────────────────────────────────────────
WEBHOOK_SECRET="94e405f2e29c2c4935c432730807cf36141bbcfdf4c633b58eb1d1e60427d326"
